            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>

        </Grid.ColumnDefinitions>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/Backgrounds/StarsHomePage.jpg"></ImageBrush>
        </Grid.Background>
        <Border BorderBrush="Black" BorderThickness="2" CornerRadius="5"
                                    Grid.Column="2" Grid.ColumnSpan="14" Grid.Row="4" Grid.RowSpan="18">
            <Grid x:Name="leftgrid" Grid.Column="2" Grid.ColumnSpan="14" Grid.Row="4" Grid.RowSpan="18">
            <Grid.Background>
                <SolidColorBrush Color="Turquoise" Opacity="0.2"></SolidColorBrush>
            </Grid.Background>
        </Grid>
        </Border>


        <Border BorderBrush="Black" BorderThickness="2" CornerRadius="15"
                                     Grid.Column="19" Grid.ColumnSpan="14" Grid.Row="4" Grid.RowSpan="18">
            <Grid x:Name="rightgrid">
                <Grid.Background>
                    <SolidColorBrush Color="Turquoise" Opacity="0.2"></SolidColorBrush>
                </Grid.Background>
            </Grid>
        </Border>


        <Button BorderBrush="Gray" Background="Maroon"  BorderThickness="6"
            Grid.Row="23" Grid.Column="1" Name="AutoBtn" CornerRadius="12" Grid.RowSpan="3"  Grid.ColumnSpan="5" Margin="2" Click="Back2_Click">
            <TextBlock x:Name="backbtn"  TextAlignment="Left" 
            VerticalAlignment="Center" FontFamily="Arial Black" 
            Text="BACK" FontSize="50"  HorizontalAlignment="Center"  Margin="1"
      ></TextBlock>
        </Button>
        <Image x:Name ="store" Grid.Column="13" Grid.ColumnSpan="9" Grid.Row="1" Grid.RowSpan="5"   Source="/Assets/Pictures/storeBtn.png"  ></Image>







    </Grid>
</Page>
